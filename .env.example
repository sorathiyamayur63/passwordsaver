# Environment Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
# DO NOT INCLUDE HARDCODED CREDS IN ACTUAL .env
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/passwordsaver?retryWrites=true&w=majority

# Security Secrets (Must be generated securely e.g., openssl rand -base64 64)
JWT_ACCESS_SECRET=generate_with_openssl_rand_base64_64_minimum_64_chars
JWT_REFRESH_SECRET=different_secret_generate_with_openssl_rand_base64_64

# Token Expirations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cross-Origin and Client Mapping
CLIENT_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_MAX=200

# NOTE: Set NODE_ENV to 'production' in deployment environments to enforce Strict secure cookies and strict HSTS