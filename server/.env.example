# Server Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env with real secrets

NODE_ENV=development
PORT=3001

# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=GENERATE_A_64_BYTE_HEX_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_BYTE_HEX_SECRET_HERE

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client URL (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

COOKIE_DOMAIN=localhost

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_MAX=200
